{
  "id": "sn.labelmaker",
  "name": "Label Maker",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "ID",
    "minVersion": "21.3.0"
  },
  "manifestVersion": 5,
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "labelTable",
      "minimumSize": {
        "width": 320,
        "height": 220
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 520,
        "height": 420
      },
      "preferredFloatingSize": {
        "width": 720,
        "height": 520
      },
      "label": {
        "default": "Label Table"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/dark@1x.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "darkest",
            "dark",
            "medium"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/light@1x.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "lightest",
            "light"
          ]
        }
      ]
    },
    {
      "type": "panel",
      "id": "config",
      "minimumSize": {
        "width": 230,
        "height": 200
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 240
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 280
      },
      "label": {
        "default": "Config"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/dark@1x.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "darkest",
            "dark",
            "medium"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/light@1x.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "lightest",
            "light"
          ]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icons/plugin@1x.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium",
        "lightest",
        "light",
        "all"
      ],
      "species": [
        "pluginList"
      ]
    }
  ]
}
