{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snicho99.github.io/label-maker/schema/label-schema-internal.json",
  "title": "Label Maker Internal InDesign Label State",
  "description": "Reference schema for the plugin-managed label state persisted inside an InDesign document label. This is internal-only state and is not part of the public Word/parser JSON contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stateVersion",
    "labels"
  ],
  "properties": {
    "stateVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "labels": {
      "type": "object",
      "description": "Map of labelId to plugin-managed persisted state.",
      "propertyNames": {
        "type": "string",
        "format": "uuid"
      },
      "additionalProperties": {
        "$ref": "#/$defs/persistedLabelState"
      }
    }
  },
  "$defs": {
    "persistedLabelState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "labelId",
        "createdAt",
        "updatedAt",
        "currentSpread",
        "masterSpread",
        "textFrameBindings",
        "lastLaidOutSnapshot",
        "lastSourceSnapshot"
      ],
      "properties": {
        "labelId": {
          "type": "string",
          "format": "uuid"
        },
        "createdAt": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "const": ""
            }
          ]
        },
        "updatedAt": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "const": ""
            }
          ]
        },
        "currentSpread": {
          "type": "string"
        },
        "masterSpread": {
          "type": [
            "string",
            "null"
          ]
        },
        "textFrameBindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/textFrameBinding"
          }
        },
        "lastLaidOutSnapshot": {
          "oneOf": [
            {
              "$ref": "label-schema.json#/$defs/label"
            },
            {
              "type": "null"
            }
          ]
        },
        "lastSourceSnapshot": {
          "oneOf": [
            {
              "$ref": "label-schema.json#/$defs/label"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "textFrameBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "labelId",
        "templateText",
        "lastRenderedText",
        "sourcePaths",
        "schemaVersion",
        "frameReference"
      ],
      "properties": {
        "labelId": {
          "type": "string",
          "format": "uuid"
        },
        "templateText": {
          "type": "string"
        },
        "lastRenderedText": {
          "type": "string"
        },
        "sourcePaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schemaVersion": {
          "type": "string"
        },
        "frameReference": {
          "type": "string"
        }
      }
    }
  }
}
